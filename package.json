{
  "name": "node-url-import",
  "version": "0.1.0",
  "type": "module",
  "description": "Node.js hook to import modules from HTTP(S) URLs",
  "main": "dist/index.js",
  "files": [
    "src",
    "dist"
  ],
  "exports": {
    ".": {
      "default": "./dist/index.js"
    },
    "./loader": {
      "default": "./dist/loader.js"
    },
    "./register": {
      "default": "./dist/register.js"
    }
  },
  "bin": {
    "node-url-import": "./dist/cli.js"
  },
  "scripts": {
    "test": "node --experimental-transform-types --disable-warning=ExperimentalWarning --import ./src/register.ts --test src/*.test.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc --declaration --sourceMap",
    "cli": "node --experimental-transform-types --disable-warning=ExperimentalWarning src/cli.ts"
  },
  "keywords": [
    "node",
    "http",
    "import",
    "require",
    "loader",
    "hook",
    "esm",
    "url",
    "deno"
  ],
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "typescript": "^5.9.3"
  }
}
